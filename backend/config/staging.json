  },
  "smtp": {
    "host": "smtp.example.com",
    "port": 587,
    "user": "user",
    "password": "password",
    "from_email": "noreply@cafeteria.local",
    "tls": true
  },
  "app": {
    "name": "Cafeteria CLEO Staging",
    "url_base": "https://staging.cafeteria.local"
  }
