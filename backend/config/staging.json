{
  "environment": "staging",
  "database": {
    "url": "postgresql://postgres:PASSWORD@localhost:5432/cafeteria_cleo_staging"
  },
  "jwt": {
    "secret_key": "staging-secret-key-change",
    "algorithm": "HS256",
    "access_token_expire_minutes": 60,
    "password_reset_expire_minutes": 30
  },
