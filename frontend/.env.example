# URL de la API del backend (default: /api si se usa proxy)
VITE_API_URL=/api

# Nombre del negocio: se muestra en la pestaña del navegador, login, sidebar y POS.
# Ejemplo: VITE_APP_NAME=Mi Cafetería
# VITE_APP_NAME=Cafetería CLEO

# Logo de la cafetería (opcional)
# Añade la URL o ruta del logo para mostrarlo en sidebar y login.
# Ejemplos: /logo.png (archivo en public/) o https://tu-sitio.com/logo.png
# VITE_LOGO_URL=/logo.png
